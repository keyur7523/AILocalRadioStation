# Backend (Nest) configuration — copy to .env to override defaults.

# HTTP port the broadcast server listens on.
PORT=3001

# Comma-separated allowed origins for CORS. Defaults to allow-all in dev.
CORS_ORIGIN=http://localhost:3000

# Folder of .mp3 files that make up the rotation (defaults to ./media).
# MEDIA_DIR=/absolute/path/to/media

# Encode settings for the live stream (constant bitrate keeps listeners synced).
STREAM_BITRATE=128k
STREAM_SAMPLE_RATE=44100
STREAM_RESTART_DELAY_MS=1000

# On-air identity, shown in the player and as ICY stream metadata.
STATION_NAME=KIND FM
STATION_FREQUENCY=98.7
STATION_TAGLINE=your local sound, on a loop
STATION_CITY=Anytown
# IANA timezone the DJ announces local time in (DST-aware). Set to your zone.
STATION_TIMEZONE=America/New_York

# DJ time-check interstitial (Phase II).
DJ_ENABLED=true
DJ_EVERY_N_SONGS=1
# Which TTS engine is bound (espeak | piper | cloud). Informational for now.
DJ_TTS_ENGINE=espeak
# Where synthesized DJ clips are cached (defaults under the OS temp dir).
# DJ_CACHE_DIR=/tmp/radio-dj-clips
