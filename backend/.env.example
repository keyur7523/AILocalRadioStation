# Backend (Nest) configuration — copy to .env to override defaults.

# HTTP port the broadcast server listens on.
PORT=3001

# Comma-separated allowed origins for CORS. Defaults to allow-all in dev.
CORS_ORIGIN=http://localhost:3000

# Folder of .mp3 files that make up the rotation (defaults to ./media).
# MEDIA_DIR=/absolute/path/to/media

# Encode settings for the live stream (constant bitrate keeps listeners synced).
STREAM_BITRATE=128k
STREAM_SAMPLE_RATE=44100
STREAM_RESTART_DELAY_MS=1000

# On-air identity, shown in the player and as ICY stream metadata.
STATION_NAME=KIND FM
STATION_FREQUENCY=98.7
STATION_TAGLINE=your local sound, on a loop
STATION_CITY=Anytown
# IANA timezone the DJ announces local time in (DST-aware). Set to your zone.
STATION_TIMEZONE=America/New_York

# DJ time-check interstitial (Phase II).
DJ_ENABLED=true
DJ_EVERY_N_SONGS=1
# Talk OVER the song's fading tail with ducking (true) vs back-to-back (false).
# false = the DJ speaks as its own segment, cleanly separated by DJ_GAP below.
DJ_OVERLAP=false
# Seconds of silence inserted between every item (song ↔ time-check ↔ song).
# Set 0 for seamless back-to-back. Only audible when DJ_OVERLAP=false.
DJ_GAP=0.5
# Seconds of music-only outro left after the DJ voice ends (overlap mode only).
DJ_TAIL_PAD=0.5
# Generate-ahead lead (seconds): synthesize the next DJ clip this many seconds
# before the current song ends, so it's ready at the boundary (no silence gap).
# Keep small so a spoken time-check stays accurate to the minute.
DJ_PREFETCH_LEAD=3
# Which TTS engine the DJ uses: espeak (default) | piper.
DJ_TTS_ENGINE=espeak
# Piper voice model path — only used when DJ_TTS_ENGINE=piper (provision in Docker).
# DJ_VOICE_MODEL=/app/voices/en_US-amy-medium.onnx
# Where synthesized DJ clips are cached (defaults under the OS temp dir).
# DJ_CACHE_DIR=/tmp/radio-dj-clips
